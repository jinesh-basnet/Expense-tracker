<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/premium_background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarStats"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="#00000000"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="Statistics"
        app:titleTextColor="@color/text_main"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarStats"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvStatsTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="📈 Monthly Breakdown"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvStatsSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Income vs Expenses each month"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"
                app:layout_constraintTop_toBottomOf="@id/tvStatsTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardTotalIncome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvStatsSubtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cardTotalExpense"
                app:layout_constraintHorizontal_chainStyle="spread">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Income"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvStatsTotalIncome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NRS 0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/income_green"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardTotalExpense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginStart="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvStatsSubtitle"
                app:layout_constraintStart_toEndOf="@id/cardTotalIncome"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Expense"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvStatsTotalExpense"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NRS 0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/expense_red"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardNetBalance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/cardTotalIncome"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Net Balance"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvStatsNetBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NRS 0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvTableTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="📋 Monthly Table"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/cardNetBalance"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardTable"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/tvTableTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TableLayout
                    android:id="@+id/tableStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="0"
                    android:padding="8dp">

                    <TableRow
                        android:background="@color/primary"
                        android:padding="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Month"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:padding="12dp"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Income"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:padding="12dp"
                            android:textSize="13sp"
                            android:gravity="end" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Expense"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:padding="12dp"
                            android:textSize="13sp"
                            android:gravity="end" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Net"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:padding="12dp"
                            android:textSize="13sp"
                            android:gravity="end" />
                    </TableRow>


                </TableLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvStatsEmpty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="No data yet. Add some transactions!"
                android:textSize="16sp"
                android:textColor="@color/text_muted"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/cardTable"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
